{
  "name": "opus-ui",
  "version": "0.2.0",
  "description": "Re-usable Vue 3 + Tailwind UI scaffolding — page shells, cards, menus, buttons, typography — extracted from OpusOS. Drop into any Laravel + Inertia or plain Vue/Vite project.",
  "type": "module",
  "license": "MIT",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./tokens.css": "./src/tokens.css",
    "./styles.css": "./src/styles.css",
    "./tailwind-preset": "./tailwind.preset.js",
    "./CLAUDE.md": "./CLAUDE.md"
  },
  "files": [
    "src",
    "stubs",
    "tailwind.preset.js",
    "README.md",
    "CLAUDE.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "peerDependenciesMeta": {
    "vue": { "optional": false }
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  },
  "keywords": [
    "vue",
    "vue3",
    "tailwind",
    "ui",
    "components",
    "laravel",
    "inertia",
    "smart-tv",
    "design-system",
    "scaffolding"
  ],
  "engines": {
    "node": ">=18"
  }
}
